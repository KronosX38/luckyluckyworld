<%- include('partials/header') %>

<!-- ENCABEZADO -->
<div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem;">
  <div>
    <a href="/admin/sorteos" style="color:#aaa; font-size:0.82rem; text-decoration:none;">
      ← Volver a sorteos
    </a>
    <p style="margin-top:0.3rem;">
      <span class="badge badge-<%= sorteo.estado %>"><%= sorteo.estado %></span>
      <% if (sorteo.folio_segob) { %>
        <span style="font-size:0.78rem; color:#aaa; margin-left:0.5rem;">
          Folio SEGOB: <%= sorteo.folio_segob %>
        </span>
      <% } %>
    </p>
  </div>
  <% if (sorteo.estado === 'activo') { %>
    <button class="btn btn-danger" onclick="cerrarSorteo(<%= sorteo.id %>)">
      <i class="fa-solid fa-stop"></i> Cerrar sorteo
    </button>
  <% } %>
</div>

<!-- CARDS STATS -->
<div class="cards-grid" style="margin-bottom:1.5rem;">
  <div class="card success">
    <div class="card-label">Vendidos</div>
    <div class="card-value"><%= stats.vendidos || 0 %></div>
    <div class="card-sub">boletos confirmados</div>
  </div>
  <div class="card">
    <div class="card-label">Disponibles</div>
    <div class="card-value"><%= stats.disponibles || 0 %></div>
    <div class="card-sub">sin vender</div>
  </div>
  <div class="card" style="border-left-color:#E8A020;">
    <div class="card-label">Reservados</div>
    <div class="card-value"><%= stats.reservados || 0 %></div>
    <div class="card-sub">en proceso de pago</div>
  </div>
  <div class="card">
    <div class="card-label">Total boletos</div>
    <div class="card-value"><%= stats.total || 0 %></div>
    <div class="card-sub">generados</div>
  </div>
</div>

<!-- GANANCIAS + INFO -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem;">

  <div class="table-wrap" style="padding:1.5rem;">
    <div class="table-title" style="margin-bottom:1rem;">💰 Ganancias</div>
    <table>
      <tr>
        <td style="color:#aaa;">Monto bruto</td>
        <td><strong>$<%= Number(ganancias.bruto).toLocaleString('es-MX') %> <%= sorteo.moneda %></strong></td>
      </tr>
      <tr>
        <td style="color:#aaa;">Comisión Stripe (3.6%)</td>
        <td style="color:#C00000;">- $<%= Number(ganancias.fee).toLocaleString('es-MX') %></td>
      </tr>
      <tr>
        <td style="color:#aaa;">Ingreso neto</td>
        <td><strong style="color:#1A7A4A;">$<%= Number(ganancias.neto).toLocaleString('es-MX') %> <%= sorteo.moneda %></strong></td>
      </tr>
    </table>
  </div>

  <!-- PREMIO -->
<div class="table-wrap" style="padding:1.5rem;">
  <div class="table-title" style="margin-bottom:1rem;">🎁 Premio e imagen</div>

  <!-- Imagen actual -->
  <div style="margin-bottom:1rem;">
    <% if (sorteo.imagen_url) { %>
      <img src="<%= sorteo.imagen_url %>" alt="Premio"
        style="width:100%; max-height:200px; object-fit:contain; border-radius:8px; background:#f0f4f8;">
    <% } else { %>
      <div style="width:100%; height:140px; background:#f0f4f8; border-radius:8px;
        display:flex; align-items:center; justify-content:center; color:#aaa; font-size:0.85rem;">
        Sin imagen del premio
      </div>
    <% } %>
  </div>

  <!-- Subir imagen -->
  <% if (sorteo.estado === 'activo' || sorteo.estado === 'borrador') { %>
    <div style="margin-bottom:1.5rem;">
      <label class="form-label">Subir imagen del premio</label>
      <input type="file" id="inputImagen" accept="image/*" class="form-input"
        style="padding:0.4rem;">
      <button class="btn btn-primary btn-sm" style="margin-top:0.5rem; width:100%;"
        onclick="subirImagen(<%= sorteo.id %>)">
        <i class="fa-solid fa-upload"></i> Subir imagen
      </button>
      <small style="color:#aaa; font-size:0.72rem;">JPG, PNG o WEBP — máximo 5MB</small>
    </div>
  <% } %>

  <table>
    <tr>
      <td style="color:#aaa;">Descripción</td>
      <td><strong><%= sorteo.premio_descripcion || '—' %></strong></td>
    </tr>
    <tr>
      <td style="color:#aaa;">Valor</td>
      <td><strong>$<%= Number(sorteo.premio_monto || 0).toLocaleString('es-MX', {minimumFractionDigits:2}) %> <%= sorteo.premio_moneda %></strong></td>
    </tr>
    <tr>
      <td style="color:#aaa;">Fecha del sorteo</td>
      <td><strong><%= sorteo.fecha_sorteo ? new Date(sorteo.fecha_sorteo).toLocaleString('es-MX') : '—' %></strong></td>
    </tr>
  </table>

  <% if (sorteo.estado === 'activo') { %>
    <div style="margin-top:1rem;">
      <label class="form-label">Actualizar link de YouTube Live</label>
      <div style="display:flex; gap:0.5rem;">
        <input type="text" id="youtubeLink" class="form-input"
          value="<%= sorteo.youtube_link || '' %>"
          placeholder="https://youtube.com/watch?v=...">
        <button class="btn btn-primary btn-sm" onclick="actualizarYoutube()">
          Guardar
        </button>
      </div>
    </div>
  <% } %>
</div>

</div>

<!-- TABLA DE BOLETOS -->
<div class="table-wrap">
  <div class="table-header">
    <span class="table-title">🎟️ Boletos (<%= boletos.length %>)</span>
    <div style="display:flex; gap:0.5rem;">
      <span class="badge badge-vendido">● Vendido</span>
      <span class="badge badge-reservado">● Reservado</span>
      <span class="badge badge-disponible">● Disponible</span>
    </div>
  </div>
  <div style="max-height:500px; overflow-y:auto;">
    <table>
      <thead style="position:sticky; top:0; z-index:1;">
        <tr>
          <th>Número</th>
          <th>Estado</th>
          <th>Comprador</th>
          <th>PIN</th>
        </tr>
      </thead>
      <tbody>
        <% boletos.forEach(b => { %>
          <tr>
            <td><strong><%= b.numero %></strong></td>
            <td><span class="badge badge-<%= b.estado %>"><%= b.estado %></span></td>
            <td><%= b.comprador_nombre || '—' %></td>
            <td>
              <% if (b.pin) { %>
                <code style="background:#f5f5f5; padding:2px 8px; border-radius:4px; font-size:0.85rem;">
                  <%= b.pin %>
                </code>
              <% } else { %>
                <span style="color:#aaa;">—</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
const token = localStorage.getItem('admin_token');

async function cerrarSorteo(id) {
  if (!confirm('¿Cerrar este sorteo? Los boletos no vendidos quedarán cancelados.')) return;
  const res = await fetch(`/api/sorteos/${id}/cerrar`, {
    method: 'PATCH',
    headers: { 'Authorization': `Bearer ${token}` }
  });
  const result = await res.json();
  if (result.ok) {
    alert('✅ Sorteo cerrado');
    window.location.reload();
  } else {
    alert('❌ ' + result.error);
  }
}

async function actualizarYoutube() {
  const link = document.getElementById('youtubeLink').value;
  const res = await fetch('/api/sorteos/<%= sorteo.id %>/youtube', {
    method: 'PATCH',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${token}`
    },
    body: JSON.stringify({ youtube_link: link })
  });
  const result = await res.json();
  alert(result.ok ? '✅ Link actualizado' : '❌ ' + result.error);
}

async function subirImagen(id) {
  const input = document.getElementById('inputImagen');
  if (!input.files[0]) {
    alert('Selecciona una imagen primero');
    return;
  }

  const formData = new FormData();
  formData.append('imagen', input.files[0]);

  const res = await fetch(`/api/admin/api/sorteos/${id}/imagen`, {
    method: 'POST',
    headers: { 'Authorization': `Bearer ${token}` },
    body: formData
  });
  const result = await res.json();

  if (result.ok) {
    alert('✅ Imagen actualizada correctamente');
    window.location.reload();
  } else {
    alert('❌ ' + result.error);
  }
}
</script>

<%- include('partials/footer') %>