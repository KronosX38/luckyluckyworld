
<body>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <span class="brand-icon">🎟️</span>
      <span class="brand-name">Lucky Lucky World</span>
    </div>

    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
        <i class="fa-solid fa-chart-line"></i> Dashboard
      </a>
      <a href="/admin/sorteos" class="nav-item <%= page === 'sorteos' ? 'active' : '' %>">
        <i class="fa-solid fa-ticket"></i> Sorteos
      </a>
      <a href="/admin/participantes" class="nav-item <%= page === 'participantes' ? 'active' : '' %>">
        <i class="fa-solid fa-users"></i> Participantes
      </a>
      <a href="/admin/ganadores" class="nav-item <%= page === 'ganadores' ? 'active' : '' %>">
        <i class="fa-solid fa-trophy"></i> Ganadores
      </a>
      <a href="/admin/verificar-pin" class="nav-item <%= page === 'verificar' ? 'active' : '' %>">
        <i class="fa-solid fa-shield-check"></i> Verificar PIN
      </a>
      <a href="/admin/configuracion" class="nav-item <%= page === 'config' ? 'active' : '' %>">
        <i class="fa-solid fa-gear"></i> Configuración
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="admin-info">
        <i class="fa-solid fa-user-circle"></i>
        <span><%= usuario.nombre %></span>
      </div>
      <a href="/admin/logout" class="btn-logout">
        <i class="fa-solid fa-right-from-bracket"></i> Salir
      </a>
    </div>
  </aside>

  <!-- CONTENIDO PRINCIPAL -->
  <main class="main-content">
    <header class="topbar">
      <h1 class="page-title"><%= title %></h1>
      <div class="topbar-right">
        <span class="badge-rol"><%= usuario.rol === 'admin_owner' ? '👑 Propietario' : '⚙️ Operador' %></span>
      </div>
    </header>

    <div class="content-body">
      <%- body %>
    </div>
  </main>

  <script src="/js/admin.js"></script>
  <%- scripts %>
</body>
</html>